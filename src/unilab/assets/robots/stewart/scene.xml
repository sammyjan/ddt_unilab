                    <geom type="box" pos="0 -0.03 0.03" size="0.02 0.005 0.04"/>
                    <geom type="box" pos="0 0.03 0.03" size="0.02 0.005 0.04"/>
                    <geom class="leg_down" pos="0 0 0.5" rgba="0 0 1 1"/>
                    <body name="leg_up10" pos="0 0 0.1">
                        <joint class="leg-slide" name="slide10"/>
